{
  "compilerOptions": {
    "target": "ES2019",
    "lib": [
      "ES2019"
    ],
    "types": [
      "google-apps-script"
    ],
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "isolatedModules": false,
    "outDir": "./dist",
    "noEmit": true // non emettere file .js, la compilazione la fa google apps script
  },
  "exclude": [
    "dist/**",
    "node_modules/**"
  ]
}